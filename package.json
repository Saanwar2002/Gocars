{
  "name": "gocars-enhancement",
  "version": "1.0.0",
  "description": "Enhanced GoCars ride-sharing application with comprehensive testing framework",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "build:agent": "tsc --project tsconfig.agent.json",
    "start:agent": "node dist/testing/main.js",
    "start:agent:dev": "ts-node src/testing/main.ts",
    "docker:build": "docker build -t gocars/testing-agent:latest .",
    "docker:run": "docker run -p 3000:3000 -p 9090:9090 gocars/testing-agent:latest",
    "k8s:deploy": "bash scripts/deploy.sh",
    "k8s:undeploy": "bash scripts/undeploy.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:performance": "jest --testPathPattern=performance",
    "test:load": "node src/testing/performance/runLoadTests.js",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "type-check": "tsc --noEmit",
    "format": "prettier --write src/**/*.{ts,tsx,js,jsx,json,css,md}",
    "format:check": "prettier --check src/**/*.{ts,tsx,js,jsx,json,css,md}",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook"
  },
  "dependencies": {
    "@genkit-ai/googleai": "^1.28.0",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@opentelemetry/exporter-jaeger": "^2.6.1",
    "@radix-ui/react-accordion": "^1.1.0",
    "@radix-ui/react-alert-dialog": "^1.0.0",
    "@radix-ui/react-avatar": "^1.0.0",
    "@radix-ui/react-checkbox": "^1.0.0",
    "@radix-ui/react-dialog": "^1.0.0",
    "@radix-ui/react-dropdown-menu": "^2.0.0",
    "@radix-ui/react-label": "^2.0.0",
    "@radix-ui/react-popover": "^1.0.0",
    "@radix-ui/react-progress": "^1.0.0",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.0.0",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.0",
    "@radix-ui/react-slider": "^1.1.0",
    "@radix-ui/react-slot": "^1.0.0",
    "@radix-ui/react-switch": "^1.0.0",
    "@radix-ui/react-tabs": "^1.0.0",
    "@radix-ui/react-toast": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.0.0",
    "autoprefixer": "^10.4.0",
    "axios": "^1.3.0",
    "baseline-browser-mapping": "^2.10.19",
    "caniuse-lite": "^1.0.30001788",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^0.2.0",
    "commander": "^9.4.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
